{
  "info": {
    "_postman_id": "d4d4df57-23e1-4b0d-bc16-13f186bcdb70",
    "name": "ATS Refiner Workflow",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Postman collection for the ATS Refiner upload -> analyze -> download workflow."
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "resumeFile",
      "value": ""
    },
    {
      "key": "jobDescription",
      "value": ""
    },
    {
      "key": "sessionId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "1) Upload Resume",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Upload request succeeded', function () {",
              "  pm.response.to.have.status(200);",
              "  const json = pm.response.json();",
              "  pm.expect(json.success).to.eql(true);",
              "  pm.expect(json.data).to.have.property('sessionId');",
              "});",
              "",
              "const json = pm.response.json();",
              "if (json && json.data && json.data.sessionId) {",
              "  pm.collectionVariables.set('sessionId', json.data.sessionId);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "file",
              "type": "file",
              "src": "{{resumeFile}}"
            }
          ]
        },
        "url": {
          "raw": "{{baseUrl}}/api/upload",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "upload"
          ]
        },
        "description": "Set `resumeFile` to a local PDF or DOCX file path before sending."
      },
      "response": []
    },
    {
      "name": "2) Analyze Resume",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"sessionId\": \"{{sessionId}}\",\n  \"jobDescription\": \"{{jobDescription}}\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/analyze",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "analyze"
          ]
        },
        "description": "Runs AI analysis using the `sessionId` captured from the upload request."
      },
      "response": []
    },
    {
      "name": "3) Download Improved Resume",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/download/{{sessionId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "download",
            "{{sessionId}}"
          ]
        },
        "description": "Downloads the improved resume payload for the analyzed session."
      },
      "response": []
    }
  ]
}
